/*
	手紙つつかれ
*/

function 手紙つつかれ {
	handleOnDoubleClickLetter();
	return 手紙つつかれ本文()+"\w9\x"+OnDisplayLetterExit()+"\w9"+手紙退場();
}

talk 手紙つつかれ本文 {
	\1\b[2]お久し振りです。\w9\w5お元気でしょうか。\w9\w5
	こちらはいつも通り、\w9\w5皆で楽しくやっています。\w9\w5
	\x\1\b[2]春になり、\w9こちらは梅の花が咲きました。\w9\w5
	白梅の花を見ると、\w9春の訪れと生命の芽吹きを感じ、\w9希望が満ちていくようです。\w9\w5\n[half]
	あなたが庭に植えたという梅も、\w9そろそろ咲いているころでしょうか。\w9\w5
	あなたはきっとそういうものを丁寧に扱うから、\w9それは綺麗な花が咲いていることでしょう。\w9\w5
	どのような花が咲いたか、\w9とても気になります。\w9\w5
	\x\1\b[2]お返事と、\w9また会える日を楽しみにしています。\w9\w5
}

